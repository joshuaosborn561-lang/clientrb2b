<div class="row">
  <div class="col">
    <h1><%= mode === 'new' ? 'New client' : 'Edit client' %></h1>
    <p class="muted">
      <strong>Required for the worker</strong> (when it loads config from this app): Slack channel ID, Slack token (read RB2B channel), SmartLead key + campaign if you want email, HeyReach key + campaign if you want LinkedIn.
      <strong>Optional:</strong> Prospeo (find work email when RB2B has none). <strong>For visit → engagement Slack posts:</strong> Slack bot token (UI). The two “secret” fields at the bottom are auto-filled on create; copy the worker config secret into Railway (<code>WORKER_CONFIG_SECRET</code>) — leave blank on edit to keep.
    </p>
  </div>
</div>

<form method="post" action="<%= mode === 'new' ? '/clients' : '/clients/' + client.id %>" class="card" autocomplete="off">
  <div class="grid">
    <div class="field">
      <label>Name</label>
      <input name="name" required value="<%= client ? client.name : '' %>" placeholder="Acme Inc" autocomplete="organization" />
    </div>

    <div class="field">
      <label>Status</label>
      <select name="status">
        <option value="active" <%= !client || client.status === 'active' ? 'selected' : '' %>>active</option>
        <option value="paused" <%= client && client.status === 'paused' ? 'selected' : '' %>>paused</option>
      </select>
    </div>

    <div class="field span-2">
      <label>Slack channel ID (RB2B alerts)</label>
      <input name="slack_channel_id" required value="<%= client ? client.slack_channel_id : '' %>" placeholder="C0123ABCDEF" class="mono" spellcheck="false" />
    </div>

    <div class="field span-2">
      <label>Slack token — worker (read channel history)</label>
      <input type="text" name="slack_token" value="" placeholder="<%= client && client.slack_token ? '(unchanged if left blank)' : 'xoxb-...' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field">
      <label>SmartLead campaign ID (email)</label>
      <input name="smartlead_campaign_id" value="<%= client && client.smartlead_campaign_id ? client.smartlead_campaign_id : '' %>" placeholder="67890" />
    </div>

    <div class="field">
      <label>HeyReach campaign ID (LinkedIn)</label>
      <input name="heyreach_campaign_id" value="<%= client && client.heyreach_campaign_id ? client.heyreach_campaign_id : '' %>" placeholder="12345" />
    </div>

    <div class="field">
      <label>SmartLead API key</label>
      <input type="text" name="smartlead_api_key" value="" placeholder="<%= client && client.smartlead_api_key ? '(unchanged if left blank)' : '' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field">
      <label>HeyReach API key</label>
      <input type="text" name="heyreach_api_key" value="" placeholder="<%= client && client.heyreach_api_key ? '(unchanged if left blank)' : '' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field span-2">
      <label>Prospeo API key (optional — enrich missing work email)</label>
      <input type="text" name="prospeo_api_key" value="" placeholder="<%= client && client.prospeo_api_key ? '(unchanged if left blank)' : 'pk_...' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field span-2">
      <label>Slack bot token — UI (optional — post “visit → first engagement” into the channel)</label>
      <input type="text" name="slack_bot_token_ui" value="" placeholder="<%= client && client.slack_bot_token_ui ? '(unchanged if left blank)' : 'xoxb-...' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field">
      <label>Touchpoint ingest secret (optional — auto on create)</label>
      <input type="text" name="touchpoint_ingest_secret" value="" placeholder="<%= client && client.touchpoint_ingest_secret ? '(unchanged if left blank)' : 'blank = random on create' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field">
      <label>Worker config secret (optional — auto on create; put same value on Railway worker)</label>
      <input type="text" name="worker_config_secret" value="" placeholder="<%= client && client.worker_config_secret ? '(unchanged if left blank)' : 'blank = random on create' %>" class="mono" spellcheck="false" autocapitalize="off" />
    </div>

    <div class="field span-2">
      <label>Notes (optional)</label>
      <textarea name="notes" rows="4" placeholder="Anything about this client..."><%= client && client.notes ? client.notes : '' %></textarea>
    </div>
  </div>

  <div class="actions">
    <a class="btn" href="<%= mode === 'new' ? '/' : '/clients/' + client.id %>">Cancel</a>
    <button class="btn primary" type="submit"><%= mode === 'new' ? 'Create client' : 'Save changes' %></button>
  </div>
</form>
