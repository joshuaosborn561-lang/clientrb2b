<% if (typeof slackOauth !== 'undefined' && slackOauth) { %>
  <p class="muted" style="margin:0 0 14px 0;padding:12px 14px;border-radius:12px;border:1px solid rgba(255,200,100,0.35);background:rgba(255,200,100,0.12);">
    <% if (slackOauth === 'missing') { %>
      <strong>Slack didn’t return an authorization code.</strong> Don’t open or bookmark <code>/auth/slack/callback</code> by itself. Open a <strong>client</strong> → <strong>Add Slack app to client workspace</strong> (or <code>/clients/YOUR-UUID/slack-install</code>), approve in Slack, and you should land back with a token saved.
    <% } else if (slackOauth === 'denied') { %>
      <strong>Slack install was cancelled.</strong> Try again from the client page.
    <% } else { %>
      Slack: <code><%= slackOauth %></code>
    <% } %>
  </p>
<% } %>

<div class="row">
  <div>
    <h2 style="margin:0 0 12px 0;">Clients</h2>
    <p class="muted" style="margin:0 0 16px 0;">Manage per-client Slack, Prospeo, SmartLead, and HeyReach settings. The legacy worker stays untouched; worker-v2 can load secrets from this UI.</p>
  </div>
  <div>
    <a class="btn primary" href="/clients/new">+ New client</a>
  </div>
</div>

<table>
  <thead>
    <tr>
      <th>Name</th>
      <th>Slack Channel ID</th>
      <th>Status</th>
      <th>Campaign IDs</th>
      <th style="text-align:right;">Actions</th>
    </tr>
  </thead>
  <tbody>
    <% if (clients.length === 0) { %>
      <tr>
        <td colspan="5" class="muted">No clients yet.</td>
      </tr>
    <% } %>
    <% for (const c of clients) { %>
      <tr>
        <td><strong><%= c.name %></strong></td>
        <td><code><%= c.slack_channel_id || '' %></code></td>
        <td><span class="pill <%= c.status === 'active' ? 'ok' : 'off' %>"><%= c.status %></span></td>
        <td class="muted">
          HeyReach (LI): <code><%= c.heyreach_campaign_id || '-' %></code><br/>
          SmartLead (email): <code><%= c.smartlead_campaign_id || '-' %></code>
        </td>
        <td style="text-align:right;">
          <a class="btn" href="/clients/<%= c.id %>">View</a>
          <a class="btn" href="/clients/<%= c.id %>/slack-install" title="Install app in that workspace">Slack</a>
          <a class="btn" href="/clients/<%= c.id %>/edit">Edit</a>
        </td>
      </tr>
    <% } %>
  </tbody>
</table>
