<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width,initial-scale=1" />
    <meta name="robots" content="noindex, nofollow" />
    <title>Slack connection · Website Visitor Automation</title>
    <style>
      :root { --bg:#0b1020; --card:#111a33; --text:#e8eeff; --muted:#9bb0ff; --border:#22315f; --accent:#6ea8fe; }
      * { box-sizing: border-box; }
      body { margin:0; min-height:100vh; display:flex; align-items:center; justify-content:center; padding:24px;
        font-family: ui-sans-serif, system-ui, -apple-system, sans-serif; background: radial-gradient(1200px 800px at 20% 10%, #15214a 0%, var(--bg) 50%, #070a14 100%); color: var(--text); }
      .card { max-width: 520px; width: 100%; background: color-mix(in srgb, var(--card), transparent 8%); border: 1px solid var(--border); border-radius: 14px; padding: 24px; }
      h1 { margin:0 0 12px; font-size: 18px; }
      p { margin:0 0 12px; color: var(--muted); font-size: 14px; line-height: 1.5; }
      a { color: var(--accent); }
      .actions { display: flex; flex-wrap: wrap; gap: 10px; margin-top: 20px; }
      .btn { display: inline-block; padding: 9px 14px; border-radius: 10px; border: 1px solid rgba(255,255,255,0.16); background: rgba(255,255,255,0.06); color: var(--text); text-decoration: none; font-weight: 600; font-size: 13px; }
      .btn:hover { border-color: rgba(110,168,254,0.5); }
      .ok { border-color: rgba(34, 197, 94, 0.4); background: rgba(34, 197, 94, 0.1); }
      .bad { border-color: rgba(255, 120, 100, 0.4); }
      code { font-size: 12px; }
    </style>
  </head>
  <body>
    <div class="card <%= isOk ? 'ok' : 'bad' %>">
      <h1><%= heading %></h1>
      <p><%- message %></p>
      <div class="actions">
        <% if (clientId) { %><a class="btn" href="/clients/<%= clientId %>">Back to client</a><% } %>
        <a class="btn" href="/">Home</a>
      </div>
    </div>
  </body>
</html>
